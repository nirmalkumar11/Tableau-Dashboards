      <aliases enabled='yes' />
      <column caption='Rating category' datatype='string' name='[Calculation_0078551140192256]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [rating] = &quot;TV-MA&quot;&#10;OR [rating] = &quot;R&quot;&#10;OR [rating] = &quot;NC-17&quot;&#10;THEN &quot;Mature&quot;&#10;&#10;ELSEIF [rating] = &quot;TV-14&quot;&#10;OR [rating] = &quot;TV-PG&quot;&#10;OR [rating] = &quot;PG-13&quot;&#10;THEN &quot;Teen&quot;&#10;&#10;ELSEIF [rating] = &quot;TV-Y&quot;&#10;OR [rating] = &quot;TV-Y7&quot;&#10;OR [rating] = &quot;TV-Y7-FV&quot;&#10;OR [rating] = &quot;TV-G&quot;&#10;OR [rating] = &quot;PG&quot;&#10;OR [rating] = &quot;G&quot;&#10;THEN &quot;Kids / Family&quot;&#10;&#10;ELSE &quot;Other&quot;&#10;END' />
      </column>
      <column caption='movie_show_ratio' datatype='real' default-format='p0.00%' name='[Calculation_0078551145717761]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ROUND(&#10;COUNT([Calculation_0078551147753474])&#10;/&#10;COUNT([Calculation_0078551147880451]), 2)' />
      </column>
      <column caption='movie' datatype='integer' name='[Calculation_0078551147753474]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [type] = &quot;Movie&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='show' datatype='integer' name='[Calculation_0078551147880451]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [type] = &quot;TV Show&quot; THEN 1 ELSE 0 END' />
      </column>
      <column caption='netflix_titles.csv' datatype='table' name='[__tableau_internal_object_id__].[netflix_titles.csv_C9C61362F41546E588C76077C8A16C3E]' role='measure' type='quantitative' />
